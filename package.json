{
  "name": "batch-mix-cut",
  "version": "0.1.17",
  "private": true,
  "type": "module",
  "description": "本地批量混剪与剪映草稿替换工具",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on tcp:5173 dist-electron/electron/main.js && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/electron/main.js\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "preview": "vite preview",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:mac:arm64": "pnpm build && electron-builder --mac --arm64",
    "dist:win": "pnpm build && electron-builder --win --x64",
    "publish:win": "pnpm build && electron-builder --win --x64 --publish always",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffmpeg-installer/win32-x64": "^4.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@ffprobe-installer/win32-x64": "^5.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.local.batchmixcut",
    "productName": "医博生物混剪工具",
    "directories": {
      "output": "release"
    },
    "artifactName": "YiboBioMixCut-${version}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.png",
      "electron/preload.cjs",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**",
      "node_modules/@ffprobe-installer/**"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "generic",
      "url": "https://github.com/PinkBoyhi/batch-mix-cut/releases/latest/download/"
    }
  }
}
